{
  "name": "unihockey-matchuhr",
  "version": "1.0.0",
  "description": "Unihockey Spieluhr MVP",
  "main": "dist/server.js",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "npx tsx watch server.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "node dist/server.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "vue": "^3.4.5",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.4.5",
    "concurrently": "^10.0.3",
    "daisyui": "^5.5.23",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
